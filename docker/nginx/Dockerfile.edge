FROM openresty/openresty:1.31.1.1-2-alpine-fat@sha256:427d94fea0c24b099e7891e8d1b7976f6d008e2d427e56bab725c8b8b293795b

# OpenResty includes the headers-more module used to remove the Server header.
# Keep the paths expected by the repository's nginx configuration.
RUN mkdir -p /etc/nginx /var/log/nginx \
    && ln -s /usr/local/openresty/nginx/conf/mime.types /etc/nginx/mime.types
